  "createfirefightingadd.ponder.high_pressure_pump_range_and_pressure.header": "\u9ad8\u538b\u6c34\u6cf5\u7684\u8ddd\u79bb\u4e0e\u538b\u529b",
  "createfirefightingadd.ponder.high_pressure_pump_range_and_pressure.text_1": "\u9ad8\u538b\u6c34\u6cf5\u4f1a\u6309\u500d\u7387\u653e\u5927 Create \u673a\u68b0\u6cf5\u7684\u57fa\u7840\u884c\u4e3a\u3002",
  "createfirefightingadd.ponder.high_pressure_pump_range_and_pressure.text_2": "\u653e\u5927\u500d\u7387\u4f1a\u63d0\u9ad8\u538b\u529b\u80fd\u591f\u4f20\u64ad\u5230\u7684\u7ba1\u9053\u8ddd\u79bb\u3002",
  "createfirefightingadd.ponder.high_pressure_pump_range_and_pressure.text_3": "\u9ed8\u8ba4 2 \u500d\u65f6\uff0cCreate \u666e\u901a\u6cf5 16 \u683c\u8ddd\u79bb\u4f1a\u53d8\u4e3a 32 \u683c\u3002",
  "createfirefightingadd.ponder.high_pressure_pump_range_and_pressure.text_4": "\u540c\u4e00\u4e2a\u500d\u7387\u4e5f\u4f1a\u653e\u5927\u6cf5\u538b\uff0c\u4f7f\u7ba1\u9053\u83b7\u5f97\u66f4\u9ad8\u6d41\u901f\u3002",
  "createfirefightingadd.ponder.high_pressure_pump_range_and_pressure.text_5": "\u53ef\u5728\u670d\u52a1\u7aef\u914d\u7f6e HighPressurePump.amplificationMultiplier \u4e2d\u540c\u65f6\u8c03\u6574\u8fd9\u4e24\u4e2a\u6570\u503c\u3002",
  "createfirefightingadd.ponder.nozzle_basic_spray.header": "\u55b7\u5934\u7c7b\u578b\u4e0e\u6d41\u4f53\u8f93\u5165",
  "createfirefightingadd.ponder.nozzle_basic_spray.text_1": "\u9525\u5f62\u55b7\u5934\u4f1a\u5f62\u6210\u8f83\u5706\u7684\u6c34\u6d41\uff0c\u6241\u53e3\u55b7\u5934\u4f1a\u5f62\u6210\u66f4\u5bbd\u7684\u7247\u72b6\u55b7\u6d41\u3002",
  "createfirefightingadd.ponder.nozzle_basic_spray.text_2": "\u901a\u8fc7\u7ba1\u9053\u5411\u55b7\u5934\u8f93\u5165\u6d41\u4f53\u3002\u8fd9\u91cc\u4f7f\u7528\u521b\u9020\u50a8\u7f50\u4f5c\u4e3a\u7d27\u51d1\u793a\u4f8b\u3002",
  "createfirefightingadd.ponder.nozzle_basic_spray.text_3": "\u6c34\u3001\u725b\u5976\u3001\u836f\u6c34\u3001\u7194\u5ca9\u3001\u53ef\u71c3\u71c3\u6599\u548c\u9f99\u606f\u90fd\u4f1a\u89e6\u53d1\u5404\u81ea\u7684\u55b7\u5c04\u884c\u4e3a\u3002",
  "createfirefightingadd.ponder.nozzle_fire_and_processing.header": "\u55b7\u5934\u4ea4\u4e92\u6548\u679c",
  "createfirefightingadd.ponder.nozzle_fire_and_processing.text_1": "\u55b7\u6d41\u53ef\u4ee5\u6cbf\u55b7\u5c04\u65b9\u5411\u63a8\u52a8\u5b9e\u4f53\u3002",
  "createfirefightingadd.ponder.nozzle_fire_and_processing.text_2": "\u7f6e\u7269\u53f0\u4e0a\u7684\u7269\u54c1\u548c\u6389\u843d\u7269\u53ef\u4ee5\u6309\u5bf9\u5e94\u7684 Create \u9f13\u98ce\u673a\u914d\u65b9\u5904\u7406\u3002",
  "createfirefightingadd.ponder.nozzle_fire_and_processing.text_3": "\u6c34\u4f1a\u7184\u706d\u53ef\u89c1\u55b7\u5c04\u8def\u5f84\u4e2d\u7684\u706b\u7130\u548c\u8425\u706b\u3002",
  "createfirefightingadd.ponder.nozzle_fire_and_processing.text_4": "\u5899\u4f53\u4f1a\u963b\u6321\u55b7\u5c04\u6548\u679c\uff0c\u56e0\u6b64\u73bb\u7483\u5899\u540e\u7684\u706b\u7130\u4e0d\u4f1a\u88ab\u6ce2\u53ca\u3002",
  "createfirefightingadd.ponder.nozzle_fluid_variants.header": "\u4e0d\u540c\u6d41\u4f53\u7684\u55b7\u5c04\u6548\u679c",
  "createfirefightingadd.ponder.nozzle_fluid_variants.text_1": "\u6539\u53d8\u50a8\u7f50\u4e2d\u7684\u6d41\u4f53\uff0c\u5c31\u4f1a\u6539\u53d8\u55b7\u5934\u7684\u884c\u4e3a\u3002",
  "createfirefightingadd.ponder.nozzle_fluid_variants.text_2": "\u7194\u5ca9\u548c\u88ab\u70b9\u71c3\u7684\u71c3\u6599\u4f1a\u6267\u884c\u9ad8\u6e29\u5904\u7406\u3001\u70b9\u706b\uff0c\u5e76\u878d\u5316\u96ea\u6216\u51b0\u3002",
  "createfirefightingadd.ponder.nozzle_fluid_variants.text_3": "\u5b89\u88c5 Create: Dragons Plus \u540e\uff0c\u9f99\u606f\u4f1a\u62e5\u6709\u4e13\u5c5e\u7c92\u5b50\u548c\u5904\u7406\u7c7b\u578b\u3002",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.header": "\u6c72\u6c34\u5668\u53d6\u6c34\u4e0e\u7ed1\u5b9a",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.text_1": "\u6c72\u6c34\u5668\u4f1a\u641c\u5bfb\u9644\u8fd1\u7684\u65e0\u9650\u6c34\u6e90\uff0c\u5e76\u652f\u6301\u5728\u7269\u7406\u7ed3\u6784\u4e0a\u5bfb\u627e\u5730\u9762\u7684\u65e0\u9650\u6c34\u6e90\u3002",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.text_2": "\u624b\u6301\u540a\u6876\u63a7\u5236\u5668\u53f3\u952e\u6c72\u6c34\u5668\uff0c\u53ef\u4ee5\u5c06\u4e24\u8005\u7ed1\u5b9a\u3002",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.text_3": "\u6c72\u6c34\u5668\u540c\u65f6\u83b7\u5f97\u5e94\u529b\u8f93\u5165\u548c\u7ea2\u77f3\u4fe1\u53f7\u65f6\u624d\u4f1a\u5de5\u4f5c\u3002",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.text_4": "\u5df2\u7ed1\u5b9a\u7684\u540a\u6876\u63a7\u5236\u5668\u4f1a\u4f18\u5148\u88ab\u8865\u6c34\u3002",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.text_5": "\u540a\u6876\u5145\u6ee1\u540e\uff0c\u5269\u4f59\u6c34\u4f1a\u8f93\u51fa\u5230\u540e\u65b9\u7ba1\u9053\u7f51\u7edc\u3002",
  "createfirefightingadd.ponder.water_intake_collection_and_binding.text_6": "\u8fde\u63a5\u7684\u50a8\u7f50\u4f1a\u5728\u540a\u6876\u83b7\u5f97\u4f9b\u6c34\u540e\u63a5\u6536\u6c34\u3002",
  "createfirefightingadd.ponder.bucket_controller_large_area_spray.header": "\u540a\u6876\u63a7\u5236\u5668\u5927\u8303\u56f4\u55b7\u6d12",
  "createfirefightingadd.ponder.bucket_controller_large_area_spray.text_1": "\u540a\u6876\u63a7\u5236\u5668\u7528\u4e8e\u5927\u8303\u56f4\u706d\u706b\uff0c\u901a\u5e38\u642d\u914d\u6c72\u6c34\u5668\u4f9b\u6c34\u3002",
  "createfirefightingadd.ponder.bucket_controller_large_area_spray.text_2": "\u8f93\u5165\u7ea2\u77f3\u4fe1\u53f7\u540e\uff0c\u540a\u6876\u4f1a\u5411\u4e0b\u55b7\u6d12\u3002",
  "createfirefightingadd.ponder.bucket_controller_large_area_spray.text_3": "\u4e0b\u843d\u7684\u6c34\u6d41\u4f1a\u8986\u76d6\u540a\u6876\u4e0b\u65b9\u7684\u5927\u7247\u533a\u57df\u3002",
  "createfirefightingadd.ponder.bucket_controller_large_area_spray.text_4": "\u4f7f\u7528\u4fa7\u9762\u7684\u6570\u503c\u8bbe\u7f6e\u53ef\u4ee5\u8c03\u6574\u55b7\u6d12\u9ad8\u5ea6\uff0c\u53c2\u6570\u8d8a\u5927\u9525\u5ea6\u8d8a\u5c0f\u3002",
  "createfirefightingadd.ponder.fire_hose_connection_and_relay.header": "\u6d88\u9632\u6c34\u5e26\u8fde\u63a5\u4e0e\u4e2d\u7ee7",
  "createfirefightingadd.ponder.fire_hose_connection_and_relay.text_1": "\u6d88\u9632\u6c34\u5e26\u53ef\u4ee5\u5728\u5916\u90e8\u6cf5\u9a71\u52a8\u4e0b\u4f20\u8f93\u6d41\u4f53\uff0c\u5e76\u4e14\u53ef\u4ee5\u8de8\u8d8a\u7269\u7406\u7ed3\u6784\u3002",
  "createfirefightingadd.ponder.fire_hose_connection_and_relay.text_2": "\u6c34\u5e26\u4f1a\u7ee7\u627f\u5916\u90e8\u6cf5\u7684\u63a8\u9001\u8ddd\u79bb\uff1a\u6c34\u5e26\u5230\u6cf5\u7684\u8ddd\u79bb + \u6c34\u5e26\u540e\u65b9\u8f93\u51fa\u8ddd\u79bb = \u5916\u90e8\u6cf5\u603b\u8f93\u51fa\u8ddd\u79bb\u3002\uff08\u652f\u6301\u975e Create \u6cf5\uff0c\u4f46\u53ef\u80fd\u5b58\u5728\u517c\u5bb9\u95ee\u9898\uff09",
  "createfirefightingadd.ponder.fire_hose_connection_and_relay.text_3": "\u624b\u6301\u9ed1\u8272\u67d3\u6599\u53f3\u952e\u4efb\u610f\u4e00\u7aef\u53ef\u4ee5\u5207\u6362\u4e3a\u9ed1\u8272\u6c34\u5e26\uff0c\u624b\u6301\u767d\u8272\u67d3\u6599\u53ef\u4ee5\u6539\u56de\u539f\u8272\u3002"
}
